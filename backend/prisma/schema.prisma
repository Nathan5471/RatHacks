generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  student
  judge
  organizer
}

enum GradeLevel {
  nine
  ten
  eleven
  twelve
}

enum Theme {
  default
  spooky
  space
  framework
}

enum Status {
  upcoming
  ongoing
  completed
}

enum EventType {
  hackathon
  ctf
}

model User {
  id                     String          @id @default(uuid())
  email                  String          @unique
  emailToken             String
  emailVerified          Boolean         @default(false)
  lastResendEmailRequest DateTime?
  passwordResetToken     String?
  passwordResetExpiry    DateTime?
  accountType            AccountType     @default(student)
  password               String
  firstName              String
  lastName               String
  schoolDivision         String?
  gradeLevel             GradeLevel?
  isGovSchool            Boolean?
  techStack              String?
  previousHackathon      Boolean?
  parentFirstName        String?
  parentLastName         String?
  parentEmail            String?
  parentPhoneNumber      String?
  contactFirstName       String?
  contactLastName        String?
  contactRelationship    String?
  contactPhoneNumber     String?
  events                 Event[]         @relation("eventParticipants")
  checkedInEvents        Event[]         @relation("eventCheckedInParticipants")
  eventIds               String[] // Event Ids
  createdEvents          Event[]         @relation("eventCreatedBy")
  teams                  Team[]
  teamId                 String?
  submittedProjects      Project[]
  judgeFeedbacks         JudgeFeedback[]
  workshops              Workshop[]      @relation("workshopParticipants")
  workshopIds            String[] // Workshop Ids
  organizedWorkshops     Workshop[]      @relation("workshopOrganizer")
  receivedEmails         EmailReceipt[]
  sentEmails             Email[]         @relation("emailSendFrom")
  validAccessTokens      String[]
  validRefreshTokens     String[]
  theme                  Theme           @default(default)
  createdAt              DateTime        @default(now())
  pageViews              PageView[]
  sessions               Session[]
}

model Invite {
  token   String      @id @default(uuid())
  email   String
  role    AccountType
  expires DateTime
}

model Team {
  id               String   @id @default(uuid())
  joinCode         String   @unique
  members          User[]
  memberIds        String[] // User Ids (max 4)
  event            Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId          String
  submittedProject Boolean  @default(false)
  project          Project?
  projectId        String? // Project Id
  createdAt        DateTime @default(now())
}

model Project {
  id               String          @id @default(uuid())
  name             String
  description      String
  codeURL          String?
  screenshotURL    String?
  videoURL         String?
  demoURL          String?
  event            Event           @relation(fields: [eventId], references: [id], onDelete: Restrict)
  eventId          String
  team             Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId           String          @unique
  judgeFeedback    JudgeFeedback[]
  judgeFeedbackIds String[] // JudgeFeedback Ids
  ranking          Int?
  createdAt        DateTime        @default(now())
  submittedBy      User?           @relation(fields: [submittedById], references: [id], onDelete: SetNull)
  submittedById    String? // User Id
  submittedAt      DateTime?
}

model JudgeFeedback {
  id                 String   @id @default(uuid())
  judge              User?    @relation(fields: [judgeId], references: [id], onDelete: SetNull)
  judgeId            String? // User Id
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId          String // Project Id
  creativityScore    Int
  functionalityScore Int
  technicalityScore  Int
  interfaceScore     Int
  feedback           String
  totalScore         Int
  createdAt          DateTime @default(now())
}

model Event {
  id                    String    @id @default(uuid())
  type                  EventType @default(hackathon)
  name                  String
  description           String
  location              String
  startDate             DateTime
  endDate               DateTime
  submissionDeadline    DateTime
  status                Status    @default(upcoming)
  releasedJudging       Boolean   @default(false)
  participants          User[]    @relation("eventParticipants")
  participantIds        String[] // User Ids
  checkedInParticipants User[]    @relation("eventCheckedInParticipants")
  checkedInIds          String[] // User Ids
  teams                 Team[]
  teamIds               String[] // Team Ids
  projects              Project[]
  projectIds            String[] // Project Ids
  createdBy             User?     @relation("eventCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdById           String? // Organizer Id
  createdAt             DateTime  @default(now())
}

model Workshop {
  id             String   @id @default(uuid())
  name           String
  description    String
  googleMeetURL  String?
  startDate      DateTime
  endDate        DateTime
  status         Status   @default(upcoming)
  participants   User[]   @relation("workshopParticipants")
  participantIds String[] // User Ids
  organizer      User?    @relation("workshopOrganizer", fields: [organizerId], references: [id], onDelete: SetNull)
  organizerId    String? // Organizer Id
  createdAt      DateTime @default(now())
}

model Email {
  id             String         @id @default(uuid())
  name           String
  messageSubject String
  messageBody    String
  sendFrom       User?          @relation("emailSendFrom", fields: [sendFromId], references: [id], onDelete: SetNull)
  sendFromId     String?
  sendAll        Boolean
  filterBy       String?
  subFilterBy    String?
  sendOnJoin     Boolean        @default(false)
  active         Boolean        @default(false) // This is for sendOnJoin emails to indicate if they should be used
  sentTo         EmailReceipt[]
  sentToIds      String[] // User Ids
  sentTimes      DateTime[] // Timestamps of when each email per user was sent (length should match sentTo)
  createdAt      DateTime       @default(now())
}

model EmailReceipt {
  id      String    @id @default(uuid())
  email   Email     @relation(fields: [emailId], references: [id], onDelete: Cascade)
  emailId String
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  String
  sentAt  DateTime  @default(now())
  seen    Boolean   @default(false) // Currently not used, but I plan on implementing this later
  seenAt  DateTime?
}

model Session {
  id              String     @id @default(uuid())
  user            User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId          String?
  pageViews       PageView[]
  sessionLength   Int?
  sessionStart    DateTime   @default(now())
  sessionEnd      DateTime   @default(now())
  operatingSystem String?
  browser         String?
  deviceType      String?
  deviceId        String     @default(uuid())
  ip              String?
}

model PageView {
  id              String   @id @default(uuid())
  url             String
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId          String?
  createdAt       DateTime @default(now())
  session         Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId       String
  operatingSystem String?
  browser         String?
  deviceType      String?
}
